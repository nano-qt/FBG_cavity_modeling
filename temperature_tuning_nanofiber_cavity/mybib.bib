@Article{Luong2016,
author={Luong, D.
and Jiang, L.
and Kim, J.
and L{\"u}tkenhaus, N.},
title={Overcoming lossy channel bounds using a single quantum repeater node},
journal={Applied Physics B},
year={2016},
month={Apr},
day={12},
volume={122},
number={4},
pages={96},
abstract={We propose a scheme for performing quantum key distribution (QKD) which has the potential to beat schemes based on the direct transmission of photons between the communicating parties. In our proposal, the communicating parties exchange photons with two quantum memories placed between them. This is a very simple quantum repeater scheme and can be implemented with currently available technology. Ideally, its secret key rate scales as the square root of the transmittivity of the optical channel, which is superior to QKD schemes based on direct transmission because key rates for the latter scale at best linearly with transmittivity. Taking into account various imperfections in each component of our setup, we present parameter regimes in which our protocol outperforms protocols based on direct transmission.},
issn={1432-0649},
doi={10.1007/s00340-016-6373-4},
url={https://doi.org/10.1007/s00340-016-6373-4}
}
